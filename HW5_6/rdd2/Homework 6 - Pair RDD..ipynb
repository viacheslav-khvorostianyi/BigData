   "source": [
    "﻿{\n",
    "  \"metadata\": {\n",
    "    \"name\": \"Homework 2 - Pair RDD\",\n",
    "    \"display_name\": \"Homework 2 - Pair RDD\",\n",
    "    \"kernelspec\": {\n",
    "      \"language\": \"scala\",\n",
    "      \"name\": \"spark2-scala\"\n",
    "    },\n",
    "    \"language_info\": {\n",
    "      \"codemirror_mode\": \"text/x-scala\",\n",
    "      \"file_extension\": \".scala\",\n",
    "      \"mimetype\": \"text/x-scala\",\n",
    "      \"name\": \"scala\",\n",
    "      \"pygments_lexer\": \"scala\"\n",
    "    }\n",
    "  },\n",
    "  \"nbformat\": 4,\n",
    "  \"nbformat_minor\": 2,\n",
    "  \"cells\": [\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 0,\n",
    "      \"metadata\": {\n",
    "        \"autoscroll\": \"auto\"\n",
    "      },\n",
    "      \"outputs\": [],\n",
    "      \"source\": \"%pyspark\\n\\ndef parse_movie_record(s):\\n    id \\u003d s.split(\\\",\\\")[0]\\n    genres \\u003d s.split(\\\",\\\")[-1]\\n    name \\u003d \\u0027,\\u0027.join(s.split(\\\",\\\")[1:-1])\\n    name \\u003d name.replace(\\u0027\\\"\\u0027,\\u0027\\u0027)\\n    return (id,name,genres)\\n\\nmovies \\u003d sc.textFile(\\u0027gs://oklev-uku-datasets/movie-ratings/movies.csv\\u0027)\\nmovies \\u003d movies.map(parse_movie_record)\\n\\nprint(movies.take(5))\\n\\nratings \\u003d sc.textFile(\\u0027gs://oklev-uku-datasets/movie-ratings/ratings.csv\\u0027)\\n\\nprint(ratings.take(5))\"\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": \"For each user, find total number of ratings provided.\"\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 2,\n",
    "      \"metadata\": {\n",
    "        \"autoscroll\": \"auto\"\n",
    "      },\n",
    "      \"outputs\": [],\n",
    "      \"source\": \"%pyspark\\nuser_rating_counts \\u003d (ratings\\n    .filter(lambda line: not line.startswith(\\\"userId\\\"))  \\n    .map(lambda line: line.split(\\\",\\\")[0])               \\n    .map(lambda userId: (userId, 1))\\n    .reduceByKey(lambda a, b: a + b)                     \\n)\\n\\nuser_rating_counts.collect()\\n\"\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": \"How many movies an average user has ranked?\"\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 4,\n",
    "      \"metadata\": {\n",
    "        \"autoscroll\": \"auto\"\n",
    "      },\n",
    "      \"outputs\": [],\n",
    "      \"source\": \"%pyspark\\nuser_rating_counts.map(lambda x: x[1]).mean()\\n\"\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": \"For each user, find the minimum, maximum and average rating he provided\\n\"\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 6,\n",
    "      \"metadata\": {\n",
    "        \"autoscroll\": \"auto\"\n",
    "      },\n",
    "      \"outputs\": [],\n",
    "      \"source\": \"%pyspark\\nuser_stats \\u003d (ratings\\n    .filter(lambda line: not line.startswith(\\\"userId\\\"))\\n    .map(lambda line: line.split(\\\",\\\"))\\n    .map(lambda f: (f[0], float(f[2])))\\n    .aggregateByKey(\\n        (float(\\\"inf\\\"), float(\\\"-inf\\\"), 0.0, 0),                \\n        lambda acc, r: (min(acc[0], r), max(acc[1], r), acc[2] + r, acc[3] + 1),\\n        lambda a, b: (min(a[0], b[0]), max(a[1], b[1]), a[2] + b[2], a[3] + b[3]),\\n    )\\n    .mapValues(lambda acc: (acc[0], acc[1], acc[2] / acc[3])) \\n)\\nuser_stats.collect()\"\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": \"Find top 10 movies by average rating\\n\"\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 8,\n",
    "      \"metadata\": {\n",
    "        \"autoscroll\": \"auto\"\n",
    "      },\n",
    "      \"outputs\": [],\n",
    "      \"source\": \"%pyspark\\nmovies \\u003d (movies\\n    .filter(lambda x: x[0] !\\u003d \\\"movieId\\\")\\n    .map(lambda x: (x[0], x[1]))                     \\n)\\n\\nmovie_avg \\u003d (ratings\\n    .filter(lambda line: not line.startswith(\\\"userId\\\"))\\n    .map(lambda line: line.split(\\\",\\\"))\\n    .map(lambda f: (f[1], (float(f[2]), 1)))          \\n    .reduceByKey(lambda a, b: (a[0] + b[0], a[1] + b[1]))  \\n    .mapValues(lambda sc: (sc[0] / sc[1], sc[1])))      \\n\\ntop10 \\u003d (movie_avg\\n    .join(movies)                                      \\n    .map(lambda kv: (kv[1][1], kv[1][0][0], kv[1][0][1]))  \\n    .takeOrdered(10, key\\u003dlambda t: -t[1])              \\n)\\n\\nprint(top10)\\n\"\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": \"Provide a list of genre preferences for each user.\\nIt should be a dataset with the following structure:\\n - userId\\n - genre name\\n - number of ratings\\n - average rating\\n\"\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"raw\",\n",
    "      \"metadata\": {\n",
    "        \"format\": \"text/plain\"\n",
    "      },\n",
    "      \"source\": \"%pyspark\\n\"\n",
    "    }\n",
    "  ]\n",
    "}\n"
   ]
  }
 ]
